# Purple-agent runtime configuration.
# Copy to .env for local runs; supplied as encrypted secrets via the
# AgentBeats Quick Submit form during evaluation.

# Model API keys. Provide whichever matches MINI_SWE_MODEL.
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: any LiteLLM-supported model ID.
#   openai/gpt-5.5                       (default)
#   openai/gpt-5-codex
#   anthropic/claude-sonnet-4-6
#   anthropic/claude-opus-4-7
# MINI_SWE_MODEL=openai/gpt-5.5

# Optional: per-instance budget caps. Defaults mirror mini-swe-agent.
# MINI_SWE_COST_LIMIT=3.0
# MINI_SWE_STEP_LIMIT=0

# Optional: server log level.
# LOG_LEVEL=INFO
