{
  manifest_version: "0.3.0",
  experimental_features: ["docker"],

  // mini-swe-agent + LiteLLM reach Anthropic directly, so we need the
  // runtime ANTHROPIC_API_KEY inside the container. We declare it here
  // with an empty default — Amber's config_schema profile rejects a
  // property that is neither in `required` nor has a `default`, so the
  // default makes this a valid optional field. AgentBeats compiles this
  // into a scenario-level property named `coding_agent_ANTHROPIC_API_KEY`
  // (role-prefixed); the platform maps Quick Submit's Participant secret
  // of the same name into it. The env template below then materializes
  // the plain `ANTHROPIC_API_KEY` env var inside our container.
  // Defensive: _alias_anthropic_api_key() in server.py also catches
  // variants like AMBER_CONFIG_CODING_AGENT_ANTHROPIC_API_KEY in case
  // the platform's prefix convention differs on future runs.
  config_schema: {
    type: "object",
    properties: {
      ANTHROPIC_API_KEY: {
        type: "string",
        default: "",
      },
    },
    required: [],
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/durga-sandeep/agentbeats-mini-swe-baseline:latest",
    entrypoint: "python -m purple.server --host 0.0.0.0 --port 9019",

    env: {
      ANTHROPIC_API_KEY: "${config.ANTHROPIC_API_KEY}",
    },

    // mini-swe-agent spawns one sibling Docker container per SWE-bench
    // task (the prebuilt jefzda/sweap-images:* image supplied by the
    // green agent in each A2A message). Mount the host docker socket so
    // the participant container can reach the daemon.
    mounts: [
      { path: "/var/run/docker.sock", from: "framework.docker" },
    ],

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9019 },
      ],
    },
  },

  // We accept inbound A2A messages from the green agent; we don't
  // initiate outbound A2A calls, so there's no `slots` block.
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: {
    a2a: "a2a",
  },

  metadata: {
    // Matches the role the SWE-bench Pro green agent routes to:
    // `self._resolve_participant_url(request.participants, "coding_agent")`.
    participant_roles: ["coding_agent"],
  },
}
