{
  manifest_version: "0.3.0",
  experimental_features: ["docker"],

  // mini-swe-agent + LiteLLM reach the model provider directly, so we
  // need the runtime API key inside the container.
  //
  // Amber's `config_schema` profile (compiler/manifest/src/
  // config_schema_profile.rs in RDI-Foundation/amber) enforces a
  // `propertyNames` regex of `^(?!.*__)[a-z][a-z0-9_]*$` — all
  // declared property names MUST be lowercase snake_case. Uppercase
  // names like `OPENAI_API_KEY` fail validation, even after AgentBeats
  // role-prefixes them (`coding_agent_OPENAI_API_KEY` still has caps).
  // We therefore declare lowercase keys here and remap them to the
  // uppercase env-var names mini-swe-agent / LiteLLM expect inside
  // `program.env` below.
  //
  // The other profile rules we conform to: every property listed in
  // `required` (no defaults), `additionalProperties: false`,
  // `secret: true` on credential fields (matches
  // examples/mixed-site/api.json5).
  config_schema: {
    type: "object",
    properties: {
      openai_api_key: { type: "string", secret: true },
      anthropic_api_key: { type: "string", secret: true },
      mini_swe_model: { type: "string" },
    },
    required: ["openai_api_key", "anthropic_api_key", "mini_swe_model"],
    additionalProperties: false,
  },

  program: {
    image: "ghcr.io/durga-sandeep/agentbeats-mini-swe-baseline:latest",
    entrypoint: "python -m purple.server --host 0.0.0.0 --port 9019",

    env: {
      OPENAI_API_KEY: "${config.openai_api_key}",
      ANTHROPIC_API_KEY: "${config.anthropic_api_key}",
      MINI_SWE_MODEL: "${config.mini_swe_model}",
    },

    // mini-swe-agent spawns one sibling Docker container per SWE-bench
    // task (the prebuilt jefzda/sweap-images:* image supplied by the
    // green agent in each A2A message). Mount the host docker socket so
    // the participant container can reach the daemon.
    mounts: [
      { path: "/var/run/docker.sock", from: "framework.docker" },
    ],

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9019 },
      ],
    },
  },

  // We accept inbound A2A messages from the green agent; we don't
  // initiate outbound A2A calls, so there's no `slots` block.
  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: {
    a2a: "a2a",
  },

  metadata: {
    // Matches the role the SWE-bench Pro green agent routes to:
    // `self._resolve_participant_url(request.participants, "coding_agent")`.
    participant_roles: ["coding_agent"],
  },
}
